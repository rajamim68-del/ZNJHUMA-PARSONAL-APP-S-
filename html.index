<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Team NJ | Shared Workspace</title>
    <!-- Google Fonts & FontAwesome for Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #0f172a;
            color: #f8fafc;
            line-height: 1.6;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header Section */
        header {
            text-align: center;
            margin-bottom: 40px;
        }

        header h1 {
            font-size: 2.5rem;
            color: #38bdf8;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        header p {
            color: #94a3b8;
            font-size: 1.1rem;
        }

        /* Banner Section */
        .banner-container {
            width: 100%;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            margin-bottom: 50px;
            border: 2px solid #1e293b;
        }

        .banner-container img {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.5s ease;
        }

        .banner-container :hover img {
            transform: scale(1.02);
        }

        /* Main Grid (Features & Creators) */
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 50px;
        }

        @media (max-width: 768px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }

        .card {
            background: #1e293b;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #334155;
        }

        .card h2 {
            color: #38bdf8;
            margin-bottom: 20px;
            font-size: 1.5rem;
            border-bottom: 2px solid #334155;
            padding-bottom: 10px;
        }

        .features-list {
            list-style: none;
        }

        .features-list li {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .features-list i {
            color: #4ade80;
        }

        /* Creators Team Styles */
        .team-flex {
            display: flex;
            justify-content: space-around;
            gap: 20px;
            margin-top: 15px;
        }

        .member {
            text-align: center;
            flex: 1;
        }

        .member img {
            width: 80px;
            height: 80px;
            background: #0f172a;
            border-radius: 50%;
            padding: 5px;
            border: 2px solid #38bdf8;
            margin-bottom: 10px;
        }

        .member h3 {
            font-size: 1.1rem;
            color: #f1f5f9;
        }

        .member p {
            font-size: 0.85rem;
            color: #94a3b8;
        }

        /* Contact Section Buttons */
        .contact-section {
            text-align: center;
            background: #1e293b;
            padding: 40px 20px;
            border-radius: 12px;
            border: 1px solid #334155;
        }

        .contact-section h2 {
            color: #38bdf8;
            margin-bottom: 25px;
        }

        .btn-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            color: #fff;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 12px rgba(0, 0, 0, 0.2);
        }

        .btn-phone { background-color: #2563eb; }
        .btn-whatsapp { background-color: #22c55e; }
        .btn-telegram { background-color: #06b6d4; }
        .btn-facebook { background-color: #1877f2; }

        footer {
            text-align: center;
            margin-top: 50px;
            color: #64748b;
            font-size: 0.9rem;
        }

        footer i {
            color: #ef4444;
        }
    </style>
</head>
<body>

    <div class="container">
        
        <!-- Header Section -->
        <header>
            <h1>
                <img src="https://raw.githubusercontent.com/Tarikul-Islam-Anik/Animated-Fluent-Emojis/master/Emojis/Hand%20Gestures/Technologist.png" alt="Emoji" width="40" height="40">
                Team NJ: Workspace
            </h1>
            <p>A collaborative coding venture brought to life by NURNOBI & JHUMA</p>
        </header>

        <!-- Imgur Banner Image -->
        <div class="banner-container">
            <img src="https://i.imgur.com/YuiR8FB.jpeg" alt="Nurnobi & Jhuma Project Banner">
        </div>

        <!-- Main Content Grid -->
        <div class="grid">
            
            <!-- Features Card -->
            <div class="card">
                <h2><i class="fa-solid fa-star"></i> Key Features</h2>
                <ul class="features-list">
                    <li><i class="fa-solid fa-circle-check"></i> ⚡ High Performance Optimized Logic</li>
                    <li><i class="fa-solid fa-circle-check"></i> 🎨 Beautiful UI/UX Modern Design</li>
                    <li><i class="fa-solid fa-circle-check"></i> 📱 Fully Responsive Layouts</li>
                    <li><i class="fa-solid fa-circle-check"></i> 🔒 Secure & Scalable Structures</li>
                </ul>
            </div>

            <!-- Creators Card -->
            <div class="card">
                <h2><i class="fa-solid fa-users"></i> The Creators</h2>
                <div class="team-flex">
                    <div class="member">
                        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=nurnobi" alt="Nurnobi">
                        <h3>NURNOBI</h3>
                        <p>👑 Lead Developer</p>
                    </div>
                    <div class="member">
                        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=jhuma" alt="Jhuma">
                        <h3>JHUMA</h3>
                        <p>🎨 UI-UX Designer</p>
                    </div>
                </div>
            </div>

        </div>

        <!-- Contact Section -->
        <div class="contact-section">
            <h2>📞 Get In Touch With Us</h2>
            <div class="btn-container">
                <a href="tel:+8801715559179" class="btn btn-phone">
                    <i class="fa-solid fa-phone"></i> Call Me
                </a>
                <a href="https://wa.me/8801715559179" target="_blank" class="btn btn-whatsapp">
                    <i class="fa-brands fa-whatsapp"></i> WhatsApp
                </a>
                <a href="https://t.me/your_telegram_username" target="_blank" class="btn btn-telegram">
                    <i class="fa-brands fa-telegram"></i> Telegram
                </a>
                <a href="https://www.facebook.com/profile.php?id=61566672951149" target="_blank" class="btn btn-facebook">
                    <i class="fa-brands fa-facebook"></i> Facebook
                </a>
            </div>
        </div>

        <!-- Footer -->
        <footer>
            <p>Made with <i class="fa-solid fa-heart"></i> by NURNOBI & JHUMA &copy; 2026</p>
        </footer>

    </div>

</body>
</html>
